datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String     // hashed password
  character Character?
  createdAt DateTime   @default(now())
}

model Character {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  level             Int                @default(1)
  xp                Int                @default(0)
  gold              Int                @default(0)
  moral             Int                @default(0)
  
  // Stats
  strength          Int                @default(5)
  resistance        Int                @default(5)
  dexterity         Int                @default(5)
  speed             Int                @default(5)
  intelligence      Int                @default(5)
  maxMana           Int                @default(20)
  willpower         Int                @default(5)
  charisma          Int                @default(5)
  
  // Unspent branch points
  branchPoints      Json               // e.g. { strength: 0, dexterity: 0, intelligence: 0, willpower: 0 }
  
  // Inventory items
  inventory         Json               // e.g. [{ id: "potion_hp", name: "Poción", count: 2, icon: "🧪" }]
  
  // Logged activities today
  activitiesToday   Json               // e.g. { cardio: true } (resets daily or tracks limits)
  
  // Activity tracking and recovery
  lastActivityAt    DateTime           @default(now())
  lastDecayAppliedAt DateTime          @default(now())
  inRecovery        Boolean            @default(false)
  recoveryStartedAt DateTime?
  
  // Backups of previous stats for recovery period
  recoveryBackup    Json?              // backup of stats and level when entering recovery
  
  activities        Activity[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Activity {
  id          String    @id @default(uuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  type        String    // e.g. 'cardio', 'strength', 'study', etc.
  xpEarned    Int
  loggedAt    DateTime  @default(now())
}
